#!/usr/bin/env bash
# Pre-push gate — runs the canonical CI gate before every push so a red build
# never reaches main. This is the guard that would have caught the po2 mypy
# regression (passed ruff locally, never ran mypy).
#
# Install once (version-controlled hooks) — via `make setup`, or directly:
#   git config core.hooksPath scripts/git-hooks
#
# Escape hatch (use sparingly — CI still runs on the server):
#   SKIP_CI_HOOK=1 git push
set -euo pipefail

if [[ "${SKIP_CI_HOOK:-}" == "1" ]]; then
  echo "pre-push: SKIP_CI_HOOK=1 set — skipping local CI gate." >&2
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
echo "pre-push: running canonical CI gate (scripts/ci.sh)…" >&2
exec "$repo_root/scripts/ci.sh"
